{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentBoard",
  "version": "0.1.0-1",
  "identifier": "com.agentboard.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:4028",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AgentBoard",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../public/assets/app_logo.png", "icons/icon.ico"],
    "resources": {
      "../sample-workspace/.agentboard/pipelines.json": "sample-workspace/.agentboard/pipelines.json",
      "../sample-workspace/.agentboard/skills/": "sample-workspace/.agentboard/skills/",
      "../sample-workspace/src/": "sample-workspace/src/"
    }
  }
}
